{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    "security:openssf-scorecard",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/New_York)"
  ],
  "dependencyDashboardTitle": "Renovate Dashboard",
  "suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "rollbackPrs": true,
  "enabledManagers": ["bun", "github-actions", "regex"],
  "ignorePaths": ["package-lock.json", "yarn.lock", "pnpm-lock.yaml"],
  "packageRules": [
    {
      "description": "Disable npm, yarn, and pnpm managers",
      "matchManagers": ["npm", "yarn", "pnpm"],
      "enabled": false
    },
    {
      "description": "Auto-merge GitHub Actions for minor and patch",
      "matchManagers": ["github-actions"],
      "matchDatasources": ["github-tags"],
      "automerge": true,
      "automergeType": "branch",
      "matchUpdateTypes": ["minor", "patch"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge non-major Bun dependency updates",
      "matchManagers": ["bun"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group Next.js ecosystem packages",
      "matchManagers": ["bun"],
      "matchPackageNames": [
        "next",
        "eslint-config-next",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "nextjs"
    },
    {
      "description": "Group Cloudflare deployment tooling",
      "matchManagers": ["bun"],
      "matchPackageNames": ["wrangler", "@opennextjs/cloudflare"],
      "groupName": "cloudflare"
    },
    {
      "description": "Group MUI packages",
      "matchManagers": ["bun"],
      "matchPackagePatterns": ["^@mui/"],
      "groupName": "mui"
    },
    {
      "description": "Keep Bun runtime pins aligned",
      "matchManagers": ["regex"],
      "matchDepNames": ["oven-sh/bun"],
      "groupName": "bun runtime",
      "automerge": true,
      "matchUpdateTypes": ["patch", "minor"]
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 5am on monday"],
    "matchManagers": ["bun"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update .bun-version pin",
      "managerFilePatterns": ["/(^|/)\\.bun-version$/"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"],
      "depNameTemplate": "oven-sh/bun",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "description": "Update setup-bun action bun-version in workflows",
      "managerFilePatterns": ["/^\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "bun-version:\\s+['\"]?(?<currentValue>\\d+\\.\\d+\\.\\d+)['\"]?"
      ],
      "depNameTemplate": "oven-sh/bun",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "node"
    }
  ]
}
