{
  "name": "witl-xyz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "deploy": "bun run build:worker && wrangler deploy",
    "preview": "opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "build:worker": "opennextjs-cloudflare build",
    "check:worker": "wrangler deploy --dry-run",
    "dev:worker": "wrangler dev --port 8771",
    "preview:worker": "bun run build:worker && bun run dev:worker",
    "deploy:worker": "bun run deploy",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "format": "prettier --write '**/*.{js,jsx,ts,tsx,json,md,yml}'",
    "format:check": "prettier --check '**/*.{js,jsx,ts,tsx,json,md,yml}'",
    "postinstall": "patch-package"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@octokit/rest": "^22.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "25.9.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "patch-package": "8.0.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "wrangler": "4.99.0"
  },
  "packageManager": "bun@1.3.9",
  "//overrides": "postcss pinned to 8.5.15 for compatibility with Tailwind CSS v4 and @tailwindcss/postcss",
  "overrides": {
    "postcss": "8.5.15"
  }
}
